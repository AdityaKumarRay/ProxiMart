// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// User roles in the ProxiMart ecosystem
enum Role {
  VENDOR
  CUSTOMER
}

/// Core user model for authentication.
/// Shared between vendors and customers — differentiated by role.
model User {
  id             String   @id @default(uuid())
  email          String   @unique
  password       String
  name           String
  phone          String?
  role           Role
  refreshToken   String?  @map("refresh_token")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  vendorProfile   VendorProfile?
  customerProfile CustomerProfile?

  @@map("users")
}

/// Vendor-specific profile with shop details and location.
/// One-to-one relation with User (role = VENDOR).
model VendorProfile {
  id              String   @id @default(uuid())
  userId          String   @unique @map("user_id")
  shopName        String   @map("shop_name")
  description     String?
  address         String
  city            String
  state           String
  pincode         String
  gstNumber       String?  @map("gst_number")
  latitude        Float?
  longitude       Float?
  deliveryRadius  Float    @default(5.0) @map("delivery_radius")
  isOpen          Boolean  @default(false) @map("is_open")
  openingTime     String?  @map("opening_time")
  closingTime     String?  @map("closing_time")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("vendor_profiles")
}

/// Customer-specific profile with delivery address and location.
/// One-to-one relation with User (role = CUSTOMER).
model CustomerProfile {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  address   String?
  city      String?
  state     String?
  pincode   String?
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("customer_profiles")
}
