// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// User roles in the ProxiMart ecosystem
enum Role {
  VENDOR
  CUSTOMER
}

/// Order lifecycle statuses
enum OrderStatus {
  PENDING
  CONFIRMED
  PACKED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

/// Payment status for an order
enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  REFUNDED
}

/// Supported payment methods
enum PaymentMethod {
  COD
  UPI
  WALLET
}

/// Core user model for authentication.
/// Shared between vendors and customers — differentiated by role.
model User {
  id             String   @id @default(uuid())
  email          String   @unique
  password       String
  name           String
  phone          String?
  role           Role
  refreshToken   String?  @map("refresh_token")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  vendorProfile   VendorProfile?
  customerProfile CustomerProfile?

  @@map("users")
}

/// Vendor-specific profile with shop details and location.
/// One-to-one relation with User (role = VENDOR).
model VendorProfile {
  id              String   @id @default(uuid())
  userId          String   @unique @map("user_id")
  shopName        String   @map("shop_name")
  description     String?
  address         String
  city            String
  state           String
  pincode         String
  gstNumber       String?  @map("gst_number")
  latitude        Float?
  longitude       Float?
  deliveryRadius  Float    @default(5.0) @map("delivery_radius")
  isOpen          Boolean  @default(false) @map("is_open")
  openingTime     String?  @map("opening_time")
  closingTime     String?  @map("closing_time")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products Product[]
  orders   Order[]

  @@map("vendor_profiles")
}

/// Customer-specific profile with delivery address and location.
/// One-to-one relation with User (role = CUSTOMER).
model CustomerProfile {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  address   String?
  city      String?
  state     String?
  pincode   String?
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@map("customer_profiles")
}

/// Product category for organizing products.
/// Categories are global (not per-vendor).
model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  products Product[]

  @@map("categories")
}

/// Product listed by a vendor with inventory tracking.
/// Belongs to a VendorProfile and optionally a Category.
model Product {
  id                String   @id @default(uuid())
  vendorProfileId   String   @map("vendor_profile_id")
  categoryId        String?  @map("category_id")
  name              String
  description       String?
  price             Float
  unit              String   @default("piece")
  imageUrl          String?  @map("image_url")
  stock             Int      @default(0)
  lowStockThreshold Int      @default(10) @map("low_stock_threshold")
  isAvailable       Boolean  @default(true) @map("is_available")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  vendorProfile VendorProfile @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
  category      Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  orderItems    OrderItem[]

  @@index([vendorProfileId])
  @@index([categoryId])
  @@index([name])
  @@map("products")
}

/// Customer order placed with a specific vendor.
/// Created atomically with OrderItems and inventory decrement.
model Order {
  id                String        @id @default(uuid())
  orderNumber       String        @unique @map("order_number")
  customerProfileId String        @map("customer_profile_id")
  vendorProfileId   String        @map("vendor_profile_id")
  status            OrderStatus   @default(PENDING)
  paymentStatus     PaymentStatus @default(PENDING) @map("payment_status")
  totalAmount       Float         @map("total_amount")
  paidAmount        Float         @default(0) @map("paid_amount")
  deliveryAddress   String        @map("delivery_address")
  notes             String?
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  customerProfile CustomerProfile @relation(fields: [customerProfileId], references: [id])
  vendorProfile   VendorProfile   @relation(fields: [vendorProfileId], references: [id])
  items           OrderItem[]
  payments        Payment[]
  receipt         Receipt?

  @@index([customerProfileId])
  @@index([vendorProfileId])
  @@index([status])
  @@map("orders")
}

/// Line item within an order.
/// Stores a snapshot of product name/price at time of order.
model OrderItem {
  id        String   @id @default(uuid())
  orderId   String   @map("order_id")
  productId String   @map("product_id")
  name      String
  price     Float
  quantity  Int
  subtotal  Float
  createdAt DateTime @default(now()) @map("created_at")

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

/// Payment record associated with an order.
/// Supports multiple partial payments per order.
model Payment {
  id        String        @id @default(uuid())
  orderId   String        @map("order_id")
  amount    Float
  method    PaymentMethod
  reference String?
  createdAt DateTime      @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("payments")
}

/// Receipt issued after order delivery.
/// One-to-one with Order, generated by vendor.
model Receipt {
  id            String   @id @default(uuid())
  orderId       String   @unique @map("order_id")
  receiptNumber String   @unique @map("receipt_number")
  totalAmount   Float    @map("total_amount")
  paidAmount    Float    @map("paid_amount")
  issuedAt      DateTime @default(now()) @map("issued_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("receipts")
}
