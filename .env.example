# Server
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/proximart?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# JWT
JWT_ACCESS_SECRET=your-access-secret-min-32-chars-long-replace-me
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-long-replace-me

# External Services
SARVAM_API_KEY=your-sarvam-api-key
ML_SERVICE_URL=http://localhost:8000

# CORS
CORS_ORIGIN=http://localhost:3000
